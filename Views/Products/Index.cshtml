@model List<Product>

<h2 class="text-2xl font-bold mb-4">Products</h2>

<a href="/Products/Create" class="inline-block mb-4 px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700">
    Add Product
</a>

<table class="min-w-full border border-gray-300 divide-y divide-gray-200">
    <thead class="bg-gray-100">
        <tr>
            <th class="px-4 py-2 text-left text-gray-700 border-b">ID</th>
            <th class="px-4 py-2 text-left text-gray-700 border-b">Name</th>
            <th class="px-4 py-2 text-left text-gray-700 border-b">Stock</th>
            <th class="px-4 py-2 text-left text-gray-700 border-b">Actions</th>
        </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
        @foreach (var p in Model)
        {
            <tr>
                <td class="px-4 py-2 border-b">@p.Id</td>
                <td class="px-4 py-2 border-b">@p.Name</td>
                <td class="px-4 py-2 border-b">@p.Stock</td>
                <td class="px-4 py-2 border-b">
                    <a href="/Products/Edit/@p.Id" class="text-blue-600 hover:underline">Edit</a> |
                    <a href="/Products/Delete/@p.Id" class="text-red-600 hover:underline">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
