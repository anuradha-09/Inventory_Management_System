@model InventoryWebApp.Models.Product

@{
    ViewData["Title"] = "Add Product";
}

<div class="max-w-md mx-auto bg-white p-6 rounded shadow-md">
    <h2 class="text-2xl font-bold mb-4">Add Product</h2>

  

    <form asp-controller="Products" asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <label class="block mb-1 font-semibold">Name:</label>
        <input name="Name" required class="w-full mb-4 px-3 py-2 border rounded" />

        <label class="block mb-1 font-semibold">Category:</label>
        <input name="Category" required class="w-full mb-4 px-3 py-2 border rounded" />

        <label class="block mb-1 font-semibold">Price:</label>
        <input name="Price" type="number" step="0.01" min="0" value="0"
               class="w-full mb-4 px-3 py-2 border rounded" />

        <label class="block mb-1 font-semibold">Stock:</label>
        <input name="Stock" type="number" min="0" value="0"
               class="w-full mb-4 px-3 py-2 border rounded" />

        <label class="block mb-1 font-semibold">Low Stock Threshold:</label>
        <input name="LowStockThreshold" type="number" min="0" value="10"
               class="w-full mb-4 px-3 py-2 border rounded" />

        <div class="flex justify-between mt-2">
            <button type="submit"
                    class="px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700">
                Save
            </button>
            <a asp-controller="Products" asp-action="Index"
               class="px-4 py-2 bg-gray-300 rounded hover:bg-gray-400">
                Cancel
            </a>
        </div>
    </form>
</div>