@using InventoryWebApp.Models
@model InventoryWebApp.Models.Home

@{
    ViewData["Title"] = "Dashboard";
}

<!-- Toast Message -->
@if (TempData["Success"] != null)
{
    <div id="toast" class="fixed top-4 right-4 bg-green-500 text-white px-6 py-3 rounded shadow-lg z-50">
        @TempData["Success"]
    </div>
    <script>setTimeout(() => document.getElementById('toast').remove(), 3000);</script>
}

<h1 class="text-3xl font-bold mb-6">Dashboard</h1>

<!-- Stats Cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 mb-10">
    <div class="border-2 border-orange-500 bg-white p-6 rounded-lg shadow text-center">
        <h3 class="text-lg font-semibold text-gray-600">Total Products</h3>
        <p class="text-4xl font-bold text-orange-500 mt-2">@Model.TotalProducts</p>
    </div>
    <div class="border-2 border-gray-500 bg-white p-6 rounded-lg shadow text-center">
        <h3 class="text-lg font-semibold text-gray-600">Total Suppliers</h3>
        <p class="text-4xl font-bold text-gray-500 mt-2">@Model.TotalSuppliers</p>
    </div>
    <div class="border-2 border-green-500 bg-white p-6 rounded-lg shadow text-center">
        <h3 class="text-lg font-semibold text-gray-600">Total Orders</h3>
        <p class="text-4xl font-bold text-green-500 mt-2">@Model.TotalOrders</p>
    </div>
    <div class="border-2 border-yellow-500 bg-white p-6 rounded-lg shadow text-center">
        <h3 class="text-lg font-semibold text-gray-600">Orders Processing</h3>
        <p class="text-4xl font-bold text-yellow-500 mt-2">@Model.OrdersProcessing</p>
    </div>
    <div class="border-2 border-blue-500 bg-white p-6 rounded-lg shadow text-center">
        <h3 class="text-lg font-semibold text-gray-600">Orders Delivered</h3>
        <p class="text-4xl font-bold text-blue-500 mt-2">@Model.OrdersDelivered</p>
    </div>
    <div class="border-2 border-red-500 bg-white p-6 rounded-lg shadow text-center">
        <h3 class="text-lg font-semibold text-gray-600">Low Stock Items</h3>
        <p class="text-4xl font-bold text-red-500 mt-2">@Model.LowStockProducts</p>
    </div>
</div>

<!-- Low Stock Alert -->
@if (Model.LowStockList.Any())
{
    <div class="bg-red-50 border border-red-300 rounded-lg p-4 mb-8">
        <h2 class="text-lg font-bold text-red-600 mb-3">?? Low Stock Alerts</h2>
        <table class="min-w-full text-sm">
            <thead>
                <tr class="text-left text-gray-600 border-b">
                    <th class="py-2 pr-4">Product</th>
                    <th class="py-2 pr-4">Category</th>
                    <th class="py-2 pr-4">Stock</th>
                    <th class="py-2">Threshold</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.LowStockList)
                {
                    <tr class="border-b hover:bg-red-100">
                        <td class="py-2 pr-4 font-medium">@p.Name</td>
                        <td class="py-2 pr-4">@p.Category</td>
                        <td class="py-2 pr-4 text-red-600 font-bold">@p.Stock</td>
                        <td class="py-2">@p.LowStockThreshold</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Recent Orders -->
@if (Model.RecentOrders.Any())
{
    <div class="bg-white border border-gray-200 rounded-lg p-4">
        <h2 class="text-lg font-bold text-gray-700 mb-3">?? Recent Orders</h2>
        <table class="min-w-full text-sm">
            <thead>
                <tr class="text-left text-gray-600 border-b">
                    <th class="py-2 pr-4">Product</th>
                    <th class="py-2 pr-4">Quantity</th>
                    <th class="py-2 pr-4">Supplier</th>
                    <th class="py-2 pr-4">Status</th>
                    <th class="py-2">Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model.RecentOrders)
                {
                    <tr class="border-b hover:bg-gray-50">
                        <td class="py-2 pr-4">@o.ProductName</td>
                        <td class="py-2 pr-4">@o.Quantity</td>
                        <td class="py-2 pr-4">@o.SupplierName</td>
                        <td class="py-2 pr-4">
                            @if (o.Status == "Processing")
                            {
                                <span class="bg-yellow-100 text-yellow-700 px-2 py-1 rounded text-xs">Processing</span>
                            }
                            else if (o.Status == "Delivered")
                            {
                                <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs">Delivered</span>
                            }
                            else
                            {
                                <span class="bg-red-100 text-red-700 px-2 py-1 rounded text-xs">Cancelled</span>
                            }
                        </td>
                        <td class="py-2">@o.OrderDate.ToString("MMM dd, yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}