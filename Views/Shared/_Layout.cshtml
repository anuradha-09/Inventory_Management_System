<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Inventory Management</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen flex flex-col">
    <!-- Navbar -->
    <header class="bg-gray-600 text-white shadow-lg">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <h1 class="text-2xl font-bold tracking-wide">Inventory Manager</h1>
            <nav class="flex items-center space-x-4 font-medium">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Home" asp-action="Index"
                       class="bg-gray-500 hover:bg-gray-400 text-white px-4 py-2 rounded transition">
                        Home
                    </a>
                    <a asp-controller="Products" asp-action="Index"
                       class="bg-gray-500 hover:bg-gray-400 text-white px-4 py-2 rounded transition">
                        Products
                    </a>
                    <a asp-controller="Orders" asp-action="Index"
                       class="bg-gray-500 hover:bg-gray-400 text-white px-4 py-2 rounded transition">
                        Orders
                    </a>
                    <a asp-controller="Suppliers" asp-action="Index"
                       class="bg-gray-500 hover:bg-gray-400 text-white px-4 py-2 rounded transition">
                        Suppliers
                    </a>
                    <span class="text-gray-300 text-sm">Hello, @User.Identity.Name!</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="inline">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded transition">
                            Logout
                        </button>
                    </form>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login"
                       class="bg-gray-500 hover:bg-gray-400 text-white px-4 py-2 rounded transition">
                        Login
                    </a>
                    <a asp-controller="Account" asp-action="Register"
                       class="bg-white hover:bg-gray-200 text-gray-700 px-4 py-2 rounded transition">
                        Register
                    </a>
                }
            </nav>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow">
        <div class="max-w-7xl mx-auto px-6 py-8">
            @RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-gray-800 text-gray-300">
        <div class="max-w-7xl mx-auto px-6 py-4 text-center text-sm">
            © @DateTime.Now.Year Inventory Management System
        </div>
    </footer>
</body>
</html>
