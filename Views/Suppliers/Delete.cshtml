@model InventoryWebApp.Models.Supplier

<h2 class="text-2xl font-bold mb-4 text-red-600">Delete Supplier</h2>

<div class="max-w-md bg-white p-6 rounded shadow-md">
    <p>Are you sure you want to delete this supplier?</p>
    <p class="mt-2"><strong>Name:</strong> @Model.Name</p>
    <p><strong>Contact:</strong> @Model.Contact</p>

    <form method="post" class="mt-4 flex justify-between">
        <button type="submit" class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700">Delete</button>
        <a href="/Suppliers" class="px-4 py-2 bg-gray-300 rounded hover:bg-gray-400">Cancel</a>
    </form>
</div>
