@model List<InventoryWebApp.Models.Supplier>

<h2 class="text-2xl font-bold mb-4">Suppliers</h2>

<a href="/Suppliers/Create" class="inline-block mb-4 px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700">
    Add Supplier
</a>

<table class="min-w-full border border-gray-300 divide-y divide-gray-200">
    <thead class="bg-gray-100">
        <tr>
            <th class="px-4 py-2 text-left text-gray-700 border-b">ID</th>
            <th class="px-4 py-2 text-left text-gray-700 border-b">Name</th>
            <th class="px-4 py-2 text-left text-gray-700 border-b">Contact</th>
            <th class="px-4 py-2 text-left text-gray-700 border-b">Actions</th>
        </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
        @foreach (var s in Model)
        {
            <tr>
                <td class="px-4 py-2 border-b">@s.Id</td>
                <td class="px-4 py-2 border-b">@s.Name</td>
                <td class="px-4 py-2 border-b">@s.Contact</td>
                <td class="px-4 py-2 border-b">
                    <a href="/Suppliers/Edit/@s.Id" class="text-blue-600 hover:underline">Edit</a> |
                    <a href="/Suppliers/Delete/@s.Id" class="text-red-600 hover:underline">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
