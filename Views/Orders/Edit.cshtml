@model InventoryWebApp.Models.Order

@{
    ViewData["Title"] = "Edit Order";
}

<div class="max-w-md mx-auto bg-white p-6 rounded shadow-md">
    <h2 class="text-2xl font-bold mb-4">Edit Order</h2>

    <form asp-controller="Orders" asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />

        <label class="block mb-1 font-semibold">Product:</label>
        <select name="ProductId" class="w-full mb-4 px-3 py-2 border rounded">
            @foreach (var p in ViewBag.Products)
            {
                if (p.Id == Model.ProductId)
                {
                    <option value="@p.Id" selected="selected">@p.Name (Stock: @p.Stock)</option>
                }
                else
                {
                    <option value="@p.Id">@p.Name (Stock: @p.Stock)</option>
                }
            }
        </select>

        <label class="block mb-1 font-semibold">Quantity:</label>
        <input type="number" name="Quantity" value="@Model.Quantity" min="1"
               class="w-full mb-4 px-3 py-2 border rounded" />

        <label class="block mb-1 font-semibold">Supplier:</label>
        <select name="SupplierName" class="w-full mb-4 px-3 py-2 border rounded">
            @foreach (var s in ViewBag.Suppliers)
            {
                if (s.Name == Model.SupplierName)
                {
                    <option value="@s.Name" selected="selected">@s.Name</option>
                }
                else
                {
                    <option value="@s.Name">@s.Name</option>
                }
            }
        </select>

        <label class="block mb-1 font-semibold">Status:</label>
        <select name="Status" class="w-full mb-4 px-3 py-2 border rounded">
            @if (Model.Status == "Processing")
            {
                <option value="Processing" selected="selected">Processing</option>
            }
            else
            {
                <option value="Processing">Processing</option>
            }
            @if (Model.Status == "Delivered")
            {
                <option value="Delivered" selected="selected">Delivered</option>
            }
            else
            {
                <option value="Delivered">Delivered</option>
            }
            @if (Model.Status == "Cancelled")
            {
                <option value="Cancelled" selected="selected">Cancelled</option>
            }
            else
            {
                <option value="Cancelled">Cancelled</option>
            }
        </select>

        <div class="flex justify-between mt-2">
            <button type="submit"
                    class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
                Update
            </button>
            <a asp-controller="Orders" asp-action="Index"
               class="px-4 py-2 bg-gray-300 rounded hover:bg-gray-400">
                Cancel
            </a>
        </div>
    </form>
</div>