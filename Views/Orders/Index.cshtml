@model List<InventoryWebApp.Models.Order>

@{
    ViewData["Title"] = "Orders";
}

<!-- Toast -->
@if (TempData["Success"] != null)
{
    <div id="toast" class="fixed top-4 right-4 bg-green-500 text-white px-6 py-3 rounded shadow-lg z-50">
        @TempData["Success"]
    </div>
    <script>setTimeout(() => document.getElementById('toast').remove(), 3000);</script>
}

<div class="flex justify-between items-center mb-4">
    <h2 class="text-2xl font-bold">Orders</h2>
    <a asp-controller="Orders" asp-action="Create"
       class="px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700">
        + Add Order
    </a>
</div>

<!-- Search -->
<input type="text" id="searchInput" placeholder="Search orders..."
       class="w-full mb-4 px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-gray-400" />

<table class="min-w-full border border-gray-300 divide-y divide-gray-200" id="orderTable">
    <thead class="bg-gray-100">
        <tr>
            <th class="px-4 py-2 text-left text-gray-700">ID</th>
            <th class="px-4 py-2 text-left text-gray-700">Product</th>
            <th class="px-4 py-2 text-left text-gray-700">Quantity</th>
            <th class="px-4 py-2 text-left text-gray-700">Supplier</th>
            <th class="px-4 py-2 text-left text-gray-700">Status</th>
            <th class="px-4 py-2 text-left text-gray-700">Date</th>
            <th class="px-4 py-2 text-left text-gray-700">Actions</th>
        </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
        @foreach (var o in Model)
        {
            <tr class="hover:bg-gray-50">
                <td class="px-4 py-2">@o.Id</td>
                <td class="px-4 py-2 font-medium">@o.ProductName</td>
                <td class="px-4 py-2">@o.Quantity</td>
                <td class="px-4 py-2">@o.SupplierName</td>
                <td class="px-4 py-2">
                    @if (o.Status == "Processing")
                    {
                        <span class="bg-yellow-100 text-yellow-700 px-2 py-1 rounded text-xs font-semibold">Processing</span>
                    }
                    else if (o.Status == "Delivered")
                    {
                        <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs font-semibold">Delivered</span>
                    }
                    else
                    {
                        <span class="bg-red-100 text-red-700 px-2 py-1 rounded text-xs font-semibold">Cancelled</span>
                    }
                </td>
                <td class="px-4 py-2">@o.OrderDate.ToString("MMM dd, yyyy")</td>
                <td class="px-4 py-2 space-x-2">
                    <a asp-controller="Orders" asp-action="Edit" asp-route-id="@o.Id"
                       class="text-blue-600 hover:underline">Edit</a>
                    <form asp-controller="Orders" asp-action="Delete" method="post" class="inline"
                          onsubmit="return confirm('Are you sure you want to delete this order?')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@o.Id" />
                        <button type="submit" class="text-red-600 hover:underline">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Search Script -->
<script>
    document.getElementById('searchInput').addEventListener('keyup', function () {
        const filter = this.value.toLowerCase();
        const rows = document.querySelectorAll('#orderTable tbody tr');
        rows.forEach(row => {
            row.style.display = row.innerText.toLowerCase().includes(filter) ? '' : 'none';
        });
    });
</script>